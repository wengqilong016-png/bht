VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_STATUS_API_BASE=http://localhost:5000
VITE_INTERNAL_API_KEY=your_internal_api_key_here
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Set to "true" to bypass Supabase Auth entirely (auth-free / local-identity mode).
# Drivers identify themselves by entering a driver ID (e.g. D-SUDI) which is
# stored in localStorage. The normal Supabase Auth login page is not shown.
# NOTE: When auth is disabled, the Supabase client stays on the "anon" role.
# Current RLS policies expect an authenticated role for reads/writes, so online
# fetch/sync will fail unless you either (a) relax RLS to allow the anon role
# or (b) route requests through a service-role proxy that enforces its own auth.
# This mode is recommended only for local/offline development unless you have
# explicitly updated your Supabase security configuration.
# Leave unset or set to "false" to keep the standard email/password login flow.
VITE_DISABLE_AUTH=false
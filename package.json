{
  "name": "bahati-jackpots",
  "private": true,
  "version": "1.0.9",
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js",
    "build": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "jest --no-coverage --passWithNoTests",
    "test:ci": "jest --no-coverage",
    "test:unit": "jest --no-coverage --testPathPattern='__tests__/(?!integration/)' --passWithNoTests",
    "test:integration": "jest --no-coverage --testPathPattern='__tests__/integration/' --passWithNoTests",
    "test:selfcheck:machine": "jest --no-coverage machineWorkflowSelfCheck",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:coverage:ci": "jest --coverage",
    "test:watch": "jest --watch --passWithNoTests",
    "test:e2e": "npx playwright test",
    "test:e2e:local-supabase": "npx playwright test e2e/driver-collection-flow.local-supabase.spec.ts",
    "test:e2e:ui": "npx playwright test --ui",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "node scripts/prune-android-web-assets.cjs && npx cap sync android",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:build:android": "npm run build && node scripts/prune-android-web-assets.cjs && npx cap sync android && cd android && ./gradlew assembleDebug",
    "cap:build:android:release": "npm run build && node scripts/prune-android-web-assets.cjs && npx cap sync android && cd android && ./gradlew assembleRelease",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "security:audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@capacitor/geolocation": "^8.2.0",
    "@sentry/react": "^10.48.0",
    "@supabase/supabase-js": "^2.103.2",
    "@tanstack/react-query": "^5.99.0",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^2.0.1",
    "exif-js": "^2.3.0",
    "idb-keyval": "^6.2.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "openai": "^6.34.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
